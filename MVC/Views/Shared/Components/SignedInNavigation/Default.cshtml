@using Microsoft.AspNetCore.Identity
@using MVC.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager
@model bool

<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
    <div class="container-fluid">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Fitness Tracker</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
            <ul class="navbar-nav flex-grow-1">
                <li class="nav-item d-flex flex-row gap-2">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a class="nav-link" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                        <a class="nav-link" asp-controller="DailyLogs" asp-action="Index">My Logs</a>
                        <a class="nav-link" asp-controller="Coach" asp-action="Index">Coaches</a>
                        @if (Model)
                        {
                            <a class="nav-link" asp-controller="Client" asp-action="Index">Clients</a>
                        }
                    }
                </li>
            </ul>
            <partial name="_LoginPartial" />
        </div>
    </div>
</nav>
