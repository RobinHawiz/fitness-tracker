@using Microsoft.AspNetCore.Identity
@using MVC.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager
@model bool

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isDashboard = currentController == "Home" && currentAction == "Dashboard";
    var isDailyLogs = currentController == "DailyLogs";
    var isCoach = currentController == "Coach";
    var isClient = currentController == "Client";
}

<nav class="navbar navbar-expand-md navbar-dark box-shadow">
    <div class="container-fluid">
        <div>
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Fitness Tracker</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="#ffffff" class="bi bi-r-circle me-1 mb-3" viewBox="0 0 16 16">
                <path d="M1 8a7 7 0 1 0 14 0A7 7 0 0 0 1 8m15 0A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.5 4.002h3.11c1.71 0 2.741.973 2.741 2.46 0 1.138-.667 1.94-1.495 2.24L11.5 12H9.98L8.52 8.924H6.836V12H5.5zm1.335 1.09v2.777h1.549c.995 0 1.573-.463 1.573-1.36 0-.913-.596-1.417-1.537-1.417z" />
            </svg>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse justify-content-between">
            <ul class="navbar-nav flex-grow-1">
                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item d-flex flex-row gap-2">
                            <a class="nav-link @(isDashboard ? "active" : "")" aria-current="@(isDashboard ? "page" : null)" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item d-flex flex-row gap-2">
                            <a class="nav-link @(isDailyLogs ? "active" : "")" aria-current="@(isDailyLogs ? "page" : null)" asp-controller="DailyLogs" asp-action="Index">My Logs</a>
                    </li>
                    <li class="nav-item d-flex flex-row gap-2">
                            <a class="nav-link @(isCoach ? "active" : "")" aria-current="@(isCoach ? "page" : null)" asp-controller="Coach" asp-action="Index">Coaches</a>
                    </li>
                    <li class="nav-item d-flex flex-row gap-2">
                        @if (Model)
                        {
                            <a class="nav-link @(isClient ? "active" : "")" aria-current="@(isClient ? "page" : null)" asp-controller="Client" asp-action="Index">Clients</a>
                        }
                    </li>
                }
            </ul>
            <partial name="_LoginPartial" />
        </div>
    </div>
</nav>
