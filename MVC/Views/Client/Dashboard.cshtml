@model MVC.Models.ClientDashboardViewModel

@{
    ViewData["Title"] = $"{Model.UserName}'s Dashboard";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <h1 class="text-purple">@ViewData["Title"]</h1>
            <p class="text-muted mb-0">
                Review @Model.UserName's body metrics, nutrition and movement for each month.
            </p>
        </div>

        @if (Model.Dashboard.AvailableDates.Count > 0)
        {
            <partial name="_DashboardMonthSelector" model="Model.Dashboard" />
        }
    </div>

    @if (Model.Dashboard.AvailableDates.Count == 0)
    {
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h2 class="h5 text-purple fw-bold">No statistics available</h2>
                <p class="text-muted">
                    @Model.UserName has not created any daily logs yet.
                </p>

                <a asp-action="Index" class="btn btn-outline-purple">
                    Back to clients
                </a>
            </div>
        </div>
    }
    else
    {
        <partial name="_DashboardStatistics" model="Model.Dashboard" />
    }

</div>