@model MVC.Models.ClientDailyLogViewModel

@{
    ViewData["Title"] = $"{Model.UserName}'s Daily Logs";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="text-purple">@Model.UserName's Daily Logs</h1>
        </div>

        <a asp-action="Index" class="btn btn-outline-purple">Back to clients</a>
    </div>

    @if (Model.DailyLogs.Count == 0)
    {
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h2 class="h5 text-purple fw-bold">No logs found</h2>
                <p class="text-muted mb-0">
                    This client has not created any daily logs yet.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.DailyLogs)
            {
                <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                    <div class="card shadow-sm h-100 daily-log-card">
                        <partial name="_DailyLogContent" model="item" />
                    </div>
                </div>
            }
        </div>
    }
</div>
