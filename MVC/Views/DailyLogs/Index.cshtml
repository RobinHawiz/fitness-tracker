@model IEnumerable<MVC.Models.DailyLogIndexViewModel>

@{
    ViewData["Title"] = "Index";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end gap-3 mb-4">
        <div>
            <h1 class="text-purple">My Logs</h1>
            <p class="text-muted mb-0">
                Review and manage your logged body metrics, nutrition and movement.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-purple text-nowrap">Create New</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h2 class="h5 text-purple fw-bold">No logs found</h2>
                <p class="text-muted mb-0">
                    You have not created any logs yet.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                    <div class="card shadow-sm h-100 daily-log-card">
                        <partial name="_DailyLogContent" model="item" />

                        <div class="card-footer bg-white d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-purple btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Delete this daily log?');">
                                <input type="submit" value="Delete" class="btn btn-outline-danger btn-sm" />
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
